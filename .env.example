# ─── Accès (mono-utilisateur) ──────────────────────────────────────────────────
# Mot de passe unique pour protéger l'accès public à l'application.
APP_PASSWORD=change-moi-en-un-mot-de-passe-fort
# Secret de signature du cookie de session (chaîne aléatoire longue) :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-moi-une-longue-chaine-aleatoire

# ─── Web Push (notifications) ──────────────────────────────────────────────────
# Générer la paire de clés avec :  npm run vapid
VAPID_PUBLIC=
VAPID_PRIVATE=
# Contact VAPID (email simple ou mailto:).
VAPID_SUBJECT=mailto:toi@exemple.fr
# Heure du rappel quotidien (HH:MM, 24h).
PUSH_TIME=20:00
# Mettre à 1 pour utiliser un cron EXTERNE à la place du planificateur interne.
# DISABLE_CRON=1
# Secret requis uniquement pour l'endpoint /api/cron/daily (cron externe).
CRON_SECRET=

# ─── Serveur (production, adapter-node) ────────────────────────────────────────
# URL publique EXACTE (protection CSRF d'adapter-node). En dev : http://localhost:5173
ORIGIN=https://habitquest.exemple.fr
HOST=127.0.0.1
PORT=3000

# ─── Base de données ───────────────────────────────────────────────────────────
# Chemin du fichier SQLite (défaut : ./data/habitquest.db).
DB_PATH=./data/habitquest.db
